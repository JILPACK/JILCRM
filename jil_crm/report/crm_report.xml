<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="jil_crm_lead_report_action" model="ir.actions.act_window">
        <field name="name">Pipeline Analysis</field>
        <field name="res_model">jil.crm.lead</field>
        <field name="view_mode">pivot,graph</field>
        <field name="search_view_id" ref="jil_crm_lead_search_view"/>
        <field name="context">{'search_default_group_stage': 1}</field>
    </record>

    <record id="report_lead_document" model="ir.actions.report">
        <field name="name">Lead Report</field>
        <field name="model">jil.crm.lead</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">jil_crm.report_lead</field>
        <field name="report_file">jil_crm.report_lead</field>
        <field name="print_report_name">'Lead - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_jil_crm_lead"/>
        <field name="binding_type">report</field>
    </record>
</odoo>