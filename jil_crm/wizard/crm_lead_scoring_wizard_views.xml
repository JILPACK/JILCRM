<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="jil_crm_lead_scoring_wizard_view" model="ir.ui.view">
        <field name="name">jil.crm.lead.scoring.wizard.form</field>
        <field name="model">jil.crm.lead.scoring.wizard</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="rule_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="action_recalculate" string="Recalculate Scores" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="jil_crm_lead_scoring_wizard_action" model="ir.actions.act_window">
        <field name="name">Recalculate Scores</field>
        <field name="res_model">jil.crm.lead.scoring.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_lead_ids': active_ids}</field>
    </record>
</odoo>
