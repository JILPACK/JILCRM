<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="jil_consultation_booking_list_view" model="ir.ui.view">
        <field name="name">jil.consultation.booking.list</field>
        <field name="model">jil.consultation.booking</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list decoration-success="status == 'confirmed'" decoration-warning="status == 'draft'" decoration-muted="status == 'cancelled'">
                <field name="name"/>
                <field name="partner_name"/>
                <field name="booking_date"/>
                <field name="booking_time"/>
                <field name="consultant_id"/>
                <field name="booking_type"/>
                <field name="status" widget="badge"/>
                <field name="source"/>
            </list>
        </field>
    </record>

    <record id="jil_consultation_booking_form_view" model="ir.ui.view">
        <field name="name">jil.consultation.booking.form</field>
        <field name="model">jil.consultation.booking</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" clickable="1"/>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary"
                            invisible="status != 'draft'"/>
                    <button name="action_complete" type="object" string="Mark Completed" class="btn-success"
                            invisible="status != 'confirmed'"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-danger"
                            invisible="status in ('completed','cancelled')"/>
                    <button name="action_send_reminder" type="object" string="Send Reminder"
                            invisible="status != 'confirmed'"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="lead_id"/>
                            <field name="partner_id"/>
                            <field name="partner_name"/>
                            <field name="partner_email"/>
                            <field name="partner_phone"/>
                        </group>
                        <group>
                            <field name="booking_date"/>
                            <field name="booking_time"/>
                            <field name="duration"/>
                            <field name="consultant_id"/>
                            <field name="booking_type"/>
                            <field name="source"/>
                        </group>
                    </group>
                    <group>
                        <field name="confirmation_sent"/>
                        <field name="reminder_sent" invisible="not reminder_sent"/>
                    </group>
                    <field name="notes"/>
                    <field name="internal_notes"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="jil_consultation_booking_action" model="ir.actions.act_window">
        <field name="name">Consultation Bookings</field>
        <field name="res_model">jil.consultation.booking</field>
        <field name="view_mode">list,form,calendar</field>
    </record>

    <record id="jil_consultation_booking_calendar_view" model="ir.ui.view">
        <field name="name">jil.consultation.booking.calendar</field>
        <field name="model">jil.consultation.booking</field>
        <field name="type">calendar</field>
        <field name="arch" type="xml">
            <calendar date_start="booking_date" color="consultant_id" string="Bookings">
                <field name="partner_name"/>
                <field name="consultant_id"/>
            </calendar>
        </field>
    </record>
</odoo>
