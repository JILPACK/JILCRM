<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="jil_lead_scoring_rule_list_view" model="ir.ui.view">
        <field name="name">jil.lead.scoring.rule.list</field>
        <field name="model">jil.lead.scoring.rule</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list editable="top" multi_edit="1">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="rule_type"/>
                <field name="score_value"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="jil_lead_scoring_rule_form_view" model="ir.ui.view">
        <field name="name">jil.lead.scoring.rule.form</field>
        <field name="model">jil.lead.scoring.rule</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="rule_type"/>
                            <field name="score_value"/>
                            <field name="apply_to"/>
                        </group>
                        <group>
                            <field name="field_name" invisible="rule_type != 'field_value'"/>
                            <field name="operator" invisible="rule_type not in ('field_value', 'revenue_range')"/>
                            <field name="field_value" invisible="rule_type != 'field_value'"/>
                            <field name="email_domain" invisible="rule_type != 'email_domain'"/>
                            <field name="tag_id" invisible="rule_type != 'tag'"/>
                            <field name="country_id" invisible="rule_type != 'country'"/>
                        </group>
                    </group>
                    <group string="Revenue Range" invisible="rule_type != 'revenue_range'">
                        <field name="min_revenue"/>
                        <field name="max_revenue"/>
                    </group>
                    <group string="Communication Count" invisible="rule_type != 'communication'">
                        <field name="min_communications"/>
                        <field name="max_communications"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="jil_lead_scoring_rule_action" model="ir.actions.act_window">
        <field name="name">Scoring Rules</field>
        <field name="res_model">jil.lead.scoring.rule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
