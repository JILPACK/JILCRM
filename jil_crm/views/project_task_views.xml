<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="jil_project_task_list_view" model="ir.ui.view">
        <field name="name">jil.project.task.list</field>
        <field name="model">jil.project.task</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list decoration-success="status == 'done'" decoration-warning="status == 'in_progress'" decoration-danger="status == 'blocked'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="assigned_to"/>
                <field name="status" widget="badge"/>
                <field name="priority" widget="priority"/>
                <field name="progress" widget="progressbar"/>
                <field name="deadline"/>
                <field name="estimated_hours"/>
                <field name="actual_hours"/>
            </list>
        </field>
    </record>

    <record id="jil_project_task_form_view" model="ir.ui.view">
        <field name="name">jil.project.task.form</field>
        <field name="model">jil.project.task</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" type="object" string="Start" class="btn-primary"
                            invisible="status != 'todo'"/>
                    <button name="action_done" type="object" string="Mark Done" class="btn-success"
                            invisible="status != 'in_progress'"/>
                    <button name="action_block" type="object" string="Mark Blocked" class="btn-danger"
                            invisible="status == 'done'"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="milestone_id"/>
                            <field name="assigned_to"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="priority" widget="priority"/>
                            <field name="progress" widget="progressbar"/>
                        </group>
                    </group>
                    <group>
                        <field name="estimated_hours"/>
                        <field name="actual_hours"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="deadline"/>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="jil_project_task_action" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">jil.project.task</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
