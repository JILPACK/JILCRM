<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="jil_project_milestone_list_view" model="ir.ui.view">
        <field name="name">jil.project.milestone.list</field>
        <field name="model">jil.project.milestone</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list>
                <field name="project_id"/>
                <field name="name"/>
                <field name="status" widget="badge"/>
                <field name="date"/>
                <field name="completed_date"/>
                <field name="progress" widget="progressbar"/>
                <field name="assigned_to"/>
            </list>
        </field>
    </record>

    <record id="jil_project_milestone_form_view" model="ir.ui.view">
        <field name="name">jil.project.milestone.form</field>
        <field name="model">jil.project.milestone</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="completed_date"/>
                            <field name="progress" widget="progressbar"/>
                        </group>
                    </group>
                    <field name="description"/>
                    <field name="deliverable"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="jil_project_milestone_action" model="ir.actions.act_window">
        <field name="name">Milestones</field>
        <field name="res_model">jil.project.milestone</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
