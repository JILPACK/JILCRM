<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="jil_transport_list_view" model="ir.ui.view">
        <field name="name">jil.transport.list</field>
        <field name="model">jil.transport</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list decoration-danger="status == 'planifie'" decoration-warning="status == 'en_cours'" decoration-success="status == 'termine'">
                <field name="name"/>
                <field name="client_id"/>
                <field name="mode"/>
                <field name="incoterm"/>
                <field name="status" widget="badge"/>
                <field name="departure_city"/>
                <field name="arrival_city"/>
                <field name="departure_date"/>
                <field name="arrival_date"/>
                <field name="carrier" optional="hide"/>
                <field name="bl_number" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="jil_transport_form_view" model="ir.ui.view">
        <field name="name">jil.transport.form</field>
        <field name="model">jil.transport</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Transport">
                <header>
                    <field name="status" widget="statusbar" clickable="True"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="client_id"/>
                            <field name="order_id"/>
                            <field name="mode"/>
                            <field name="incoterm"/>
                            <field name="carrier"/>
                            <field name="bl_number"/>
                        </group>
                        <group string="Route">
                            <field name="departure_city"/>
                            <field name="departure_date"/>
                            <field name="arrival_city"/>
                            <field name="arrival_date"/>
                            <field name="eta"/>
                        </group>
                    </group>
                    <group string="Details">
                        <field name="documents" placeholder="Documents..."/>
                        <field name="notes" placeholder="Internal notes..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="jil_transport_search_view" model="ir.ui.view">
        <field name="name">jil.transport.search</field>
        <field name="model">jil.transport</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="client_id"/>
                <field name="bl_number"/>
                <field name="carrier"/>
                <filter name="filter_planified" string="Planified" domain="[('status', '=', 'planifie')]"/>
                <filter name="filter_in_progress" string="In Progress" domain="[('status', '=', 'en_cours')]"/>
                <filter name="filter_done" string="Completed" domain="[('status', '=', 'termine')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_mode" string="Mode" context="{'group_by': 'mode'}"/>
                    <filter name="group_incoterm" string="Incoterm" context="{'group_by': 'incoterm'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="jil_transport_action" model="ir.actions.act_window">
        <field name="name">Transports</field>
        <field name="res_model">jil.transport</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="jil_transport_search_view"/>
    </record>
</odoo>
