<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="jil_crm_lead_list_view" model="ir.ui.view">
        <field name="name">jil.crm.lead.list</field>
        <field name="model">jil.crm.lead</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list decoration-danger="priority == '3'" decoration-info="type == 'lead'" decoration-success="stage_id.is_won == True">
                <field name="name" string="Subject"/>
                <field name="partner_name" string="Customer"/>
                <field name="type" widget="badge"/>
                <field name="stage_id" optional="show"/>
                <field name="priority" widget="priority" optional="show"/>
                <field name="user_id" optional="hide"/>
                <field name="expected_revenue" widget="monetary" optional="show"/>
                <field name="probability" widget="progressbar" optional="show"/>
                <field name="date_deadline" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="jil_crm_lead_form_view" model="ir.ui.view">
        <field name="name">jil.crm.lead.form</field>
        <field name="model">jil.crm.lead</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Lead / Opportunity">
                <header>
                    <button name="action_convert_to_opportunity" type="object"
                            string="Convert to Opportunity" class="btn-primary"
                            invisible="type == 'opportunity'"/>
                    <button name="action_set_won" type="object"
                            string="Mark Won" class="btn-success"
                            invisible="stage_id.is_won == True or stage_id.is_lost == True"/>
                    <button name="action_set_lost" type="object"
                            string="Mark Lost" class="btn-danger"
                            invisible="stage_id.is_won == True or stage_id.is_lost == True"/>
                    <field name="stage_id" widget="statusbar" clickable="True"
                           statusbar_visible="jil_crm_stage_new,jil_crm_stage_qualified,jil_crm_stage_proposal,jil_crm_stage_negotiation,jil_crm_stage_won"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    <button name="action_view_communications" type="object"
                            class="oe_stat_button" icon="fa-phone"
                            context="{'default_lead_id': id}">
                            <div class="o_stat_info">
                                <field name="communication_count"/>
                                <span class="o_stat_text">Communications</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" string="Subject"/>
                        <h1>
                            <field name="name" placeholder="e.g. Customer request for packaging"/>
                        </h1>
                        <group>
                            <field name="partner_id" placeholder="Search or create customer"/>
                            <field name="partner_name" placeholder="Customer name"
                                   invisible="partner_id != False"/>
                            <field name="email_from" placeholder="email@example.com"/>
                            <field name="phone" placeholder="Phone number"/>
                            <field name="mobile" placeholder="Mobile number"/>
                        </group>
                    </div>
                    <notebook>
                        <page string="Details" name="details">
                            <group>
                                <group>
                                    <field name="type"/>
                                    <field name="priority" widget="priority"/>
                                    <field name="user_id"/>
                                    <field name="team_id"/>
                                    <field name="tag_ids" widget="many2many_tags"/>
                                </group>
                                <group>
                                    <field name="expected_revenue"/>
                                    <field name="probability" widget="progressbar"/>
                                    <field name="date_deadline"/>
                                    <field name="date_open"/>
                                    <field name="date_close"/>
                                </group>
                            </group>
                            <separator string="Score &amp; Grade"/>
                            <group>
                                <field name="score" widget="progressbar"/>
                                <field name="score_grade"/>
                                <field name="score_engagement"/>
                                <field name="score_behavior"/>
                                <field name="score_demographic"/>
                            </group>
                            <separator string="Address"/>
                            <field name="partner_id" placeholder="Search customer for address..."
                                    invisible="partner_id != False"/>
                        </page>
                        <page string="Capture &amp; Assignment" name="capture">
                            <group>
                                <group string="Capture Info">
                                    <field name="capture_source"/>
                                    <field name="capture_url"/>
                                    <field name="capture_form_id"/>
                                    <field name="consent_given"/>
                                </group>
                                <group string="Assignment">
                                    <field name="assignment_rule_id"/>
                                    <field name="assignment_date"/>
                                    <field name="assignment_auto"/>
                                </group>
                            </group>
                            <group string="Nurturing">
                                <field name="nurturing_campaign_id"/>
                                <field name="nurturing_status"/>
                                <field name="nurturing_start_date"/>
                                <field name="nurturing_last_action"/>
                            </group>
                            <group string="Follow-ups">
                                <field name="follow_up_count"/>
                                <field name="last_follow_up_date"/>
                                <field name="next_follow_up_date"/>
                                <field name="automated_email_sent"/>
                            </group>
                        </page>
                        <page string="Vente" name="vente">
                            <group>
                                <group string="Devis &amp; BC">
                                    <field name="quotation_ref"/>
                                    <field name="bc_ref"/>
                                    <field name="bc_date"/>
                                    <field name="bc_validated"/>
                                    <field name="correction_bc"/>
                                </group>
                                <group string="Livraison">
                                    <field name="delivery_note_ref"/>
                                    <field name="date_deadline"/>
                                </group>
                            </group>
                            <separator string="Notes"/>
                            <field name="description" placeholder="Notes de vente..."/>
                            <field name="lost_reason" placeholder="Raison si perdu..."
                                    invisible="stage_id.is_lost != True"/>
                        </page>
                        <page string="Logistique" name="logistique">
                            <group>
                                <group string="Transport">
                                    <field name="transport_mode"/>
                                    <field name="incoterm"/>
                                    <field name="incoterm_place"/>
                                    <field name="tracking_ref"/>
                                    <field name="bl_ref"/>
                                </group>
                                <group string="Livraison &amp; Entrepôt">
                                    <field name="estimated_delivery"/>
                                    <field name="delivery_date"/>
                                    <field name="warehouse_location"/>
                                </group>
                            </group>
                            <group string="Douane">
                                <field name="customs_cleared"/>
                                <field name="customs_date" invisible="not customs_cleared"/>
                            </group>
                            <field name="shipping_notes" placeholder="Notes transport..."/>
                        </page>
                        <page string="Comptabilité" name="comptabilite">
                            <group>
                                <group string="Facturation">
                                    <field name="invoice_ref"/>
                                    <field name="invoice_date"/>
                                    <field name="invoice_due_date"/>
                                </group>
                                <group string="Paiement">
                                    <field name="payment_status"/>
                                    <field name="payment_date" invisible="payment_status == 'unpaid'"/>
                                    <field name="payment_method"/>
                                </group>
                            </group>
                            <group string="Recouvrement">
                                <field name="relance_stage"/>
                                <field name="relance_date" invisible="relance_stage == 'none'"/>
                            </group>
                            <field name="accounting_notes" placeholder="Notes comptables..."/>
                        </page>
                        <page string="Direction" name="direction">
                            <group>
                                <group string="Décisions">
                                    <field name="decision_ref"/>
                                    <field name="decision_date"/>
                                    <field name="decision_type"/>
                                    <field name="approved_by_dg"/>
                                    <field name="approval_date" invisible="not approved_by_dg"/>
                                </group>
                                <group string="Réclamations">
                                    <field name="reclamation_date"/>
                                    <field name="reclamation_status"/>
                                </group>
                            </group>
                            <field name="reclamation_resolution" placeholder="Résolution réclamation..."
                                    invisible="reclamation_status not in ('traitee', 'cloturee')"/>
                            <field name="direction_notes" placeholder="Notes direction..."/>
                        </page>
                        <page string="Achats" name="achats">
                            <group>
                                <group string="Fournisseur">
                                    <field name="supplier_id"/>
                                    <field name="purchase_order_ref"/>
                                </group>
                                <group string="Approvisionnement">
                                    <field name="purchase_need_date"/>
                                    <field name="purchase_priority"/>
                                    <field name="purchase_stock_security"/>
                                </group>
                            </group>
                            <field name="purchase_notes" placeholder="Notes achats..."/>
                        </page>
                        <page string="Deal Info" name="deal">
                            <group>
                                <field name="deal_value"/>
                                <field name="deal_close_probability"/>
                                <field name="deal_expected_close"/>
                                <field name="deal_stage_duration"/>
                                <field name="deal_age"/>
                            </group>
                        </page>
                        <page string="Context MCP" name="context">
                            <group>
                                <field name="context_id"/>
                                <field name="context_last_sync"/>
                                <field name="context_sync_status"/>
                            </group>
                        </page>
                        <page string="Communications" name="communications">
                            <field name="communication_ids" readonly="0">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="communication_type"/>
                                    <field name="summary"/>
                                    <field name="user_id"/>
                                    <field name="next_action"/>
                                    <field name="next_action_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="jil_crm_lead_kanban_view" model="ir.ui.view">
        <field name="name">jil.crm.lead.kanban</field>
        <field name="model">jil.crm.lead</field>
        <field name="type">kanban</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_mobile">
                <field name="name"/>
                <field name="partner_name"/>
                <field name="expected_revenue"/>
                <field name="probability"/>
                <field name="priority"/>
                <field name="stage_id"/>
                <field name="type"/>
                <field name="color"/>
                <field name="user_id"/>
                <field name="date_deadline"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                        <field name="partner_name"/>
                                    </div>
                                </div>
                                <div class="o_kanban_card_header_right">
                                    <field name="priority" widget="priority"/>
                                </div>
                            </div>
                            <div class="oe_kanban_content">
                                <div class="row">
                                    <div class="col-6">
                                        <field name="expected_revenue" widget="monetary"/>
                                    </div>
                                    <div class="col-6 text-right">
                                        <field name="probability" widget="progressbar"/>
                                    </div>
                                </div>
                                <div class="row mt-2">
                                    <div class="col-6">
                                        <field name="type" widget="badge"/>
                                    </div>
                                    <div class="col-6 text-right">
                                        <field name="date_deadline"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <field name="user_id" avatar="true"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="jil_crm_lead_search_view" model="ir.ui.view">
        <field name="name">jil.crm.lead.search</field>
        <field name="model">jil.crm.lead</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Subject"/>
                <field name="partner_name" string="Customer"/>
                <field name="email_from" string="Email"/>
                <field name="phone" string="Phone"/>
                <filter name="filter_my_leads" string="My Leads"
                        domain="[('user_id', '=', uid)]"/>
                <filter name="filter_lead" string="Lead"
                        domain="[('type', '=', 'lead')]"/>
                <filter name="filter_opportunity" string="Opportunity"
                        domain="[('type', '=', 'opportunity')]"/>
                <separator/>
                <filter name="filter_won" string="Won"
                        domain="[('stage_id.is_won', '=', True)]"/>
                <filter name="filter_lost" string="Lost"
                        domain="[('stage_id.is_lost', '=', True)]"/>
                <separator/>
                <filter name="filter_high_score" string="High Score"
                        domain="[('score', '>=', 60)]"/>
                <filter name="filter_medium_score" string="Medium Score"
                        domain="[('score', '>=', 30), ('score', '&lt;', 60)]"/>
                <filter name="filter_low_score" string="Low Score"
                        domain="[('score', '&lt;', 30)]"/>
                <separator/>
                <filter name="filter_website" string="Website Leads"
                        domain="[('capture_source', '=', 'website')]"/>
                <filter name="filter_chatbot" string="Chatbot Leads"
                        domain="[('capture_source', '=', 'chatbot')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_stage" string="Stage"
                            context="{'group_by': 'stage_id'}"/>
                    <filter name="group_user" string="Salesperson"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_team" string="Sales Team"
                            context="{'group_by': 'team_id'}"/>
                    <filter name="group_priority" string="Priority"
                            context="{'group_by': 'priority'}"/>
                    <filter name="group_score_grade" string="Score Grade"
                            context="{'group_by': 'score_grade'}"/>
                    <filter name="group_capture_source" string="Capture Source"
                            context="{'group_by': 'capture_source'}"/>
                    <filter name="group_nurturing_status" string="Nurturing Status"
                            context="{'group_by': 'nurturing_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="jil_crm_lead_pivot_view" model="ir.ui.view">
        <field name="name">jil.crm.lead.pivot</field>
        <field name="model">jil.crm.lead</field>
        <field name="type">pivot</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="expected_revenue" type="measure"/>
                <field name="probability" type="measure"/>
                <field name="score" type="measure"/>
                <field name="stage_id" type="row"/>
                <field name="user_id" type="col"/>
                <field name="capture_source" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="jil_crm_lead_graph_view" model="ir.ui.view">
        <field name="name">jil.crm.lead.graph</field>
        <field name="model">jil.crm.lead</field>
        <field name="type">graph</field>
        <field name="arch" type="xml">
            <graph type="bar">
                <field name="expected_revenue" type="measure"/>
                <field name="stage_id" type="row"/>
                <field name="user_id" type="col"/>
            </graph>
        </field>
    </record>

    <!-- Calendar View -->
    <record id="jil_crm_lead_calendar_view" model="ir.ui.view">
        <field name="name">jil.crm.lead.calendar</field>
        <field name="model">jil.crm.lead</field>
        <field name="type">calendar</field>
        <field name="arch" type="xml">
            <calendar date_start="date_open" date_stop="date_deadline"
                      color="user_id" string="Leads">
                <field name="name"/>
                <field name="partner_name"/>
                <field name="user_id"/>
            </calendar>
        </field>
    </record>

    <!-- Action -->
    <record id="jil_crm_lead_action" model="ir.actions.act_window">
        <field name="name">Leads</field>
        <field name="res_model">jil.crm.lead</field>
        <field name="view_mode">kanban,list,form,pivot,graph,calendar</field>
        <field name="search_view_id" ref="jil_crm_lead_search_view"/>
        <field name="context">{'default_type': 'lead'}</field>
    </record>

    <!-- Opportunities Action -->
    <record id="jil_crm_opportunity_action" model="ir.actions.act_window">
        <field name="name">Opportunities</field>
        <field name="res_model">jil.crm.lead</field>
        <field name="view_mode">kanban,list,form,pivot,graph</field>
        <field name="search_view_id" ref="jil_crm_lead_search_view"/>
        <field name="domain">[('type', '=', 'opportunity')]</field>
        <field name="context">{'default_type': 'opportunity'}</field>
    </record>

    <!-- Pipeline Action -->
    <record id="jil_crm_pipeline_action" model="ir.actions.act_window">
        <field name="name">Pipeline</field>
        <field name="res_model">jil.crm.lead</field>
        <field name="view_mode">kanban,list,form,pivot,graph</field>
        <field name="search_view_id" ref="jil_crm_lead_search_view"/>
        <field name="domain">[('type', '=', 'opportunity'), ('stage_id.is_lost', '=', False), ('stage_id.is_won', '=', False)]</field>
        <field name="context">{'default_type': 'opportunity'}</field>
    </record>

    <!-- Stage Views -->
    <record id="jil_crm_stage_list_view" model="ir.ui.view">
        <field name="name">jil.crm.stage.list</field>
        <field name="model">jil.crm.stage</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="probability"/>
                <field name="is_default"/>
                <field name="is_won"/>
                <field name="is_lost"/>
                <field name="lead_count"/>
            </list>
        </field>
    </record>

    <record id="jil_crm_stage_form_view" model="ir.ui.view">
        <field name="name">jil.crm.stage.form</field>
        <field name="model">jil.crm.stage</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="probability"/>
                        <field name="is_default"/>
                        <field name="is_won"/>
                        <field name="is_lost"/>
                        <field name="color"/>
                        <field name="team_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="jil_crm_stage_action" model="ir.actions.act_window">
        <field name="name">Stages</field>
        <field name="res_model">jil.crm.stage</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
