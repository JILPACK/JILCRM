<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="jil_consultant_availability_list_view" model="ir.ui.view">
        <field name="name">jil.consultant.availability.list</field>
        <field name="model">jil.consultant.availability</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="user_id"/>
                <field name="day_of_week"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="slot_duration"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="jil_consultant_availability_form_view" model="ir.ui.view">
        <field name="name">jil.consultant.availability.form</field>
        <field name="model">jil.consultant.availability</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="day_of_week"/>
                        <field name="start_time"/>
                        <field name="end_time"/>
                        <field name="slot_duration"/>
                        <field name="max_bookings_per_slot"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="jil_consultant_availability_action" model="ir.actions.act_window">
        <field name="name">Availability</field>
        <field name="res_model">jil.consultant.availability</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
