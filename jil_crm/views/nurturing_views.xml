<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="jil_nurturing_campaign_list_view" model="ir.ui.view">
        <field name="name">jil.nurturing.campaign.list</field>
        <field name="model">jil.nurturing.campaign</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list decoration-success="conversion_rate > 20" decoration-info="conversion_rate > 10">
                <field name="name"/>
                <field name="campaign_type"/>
                <field name="active"/>
                <field name="start_date"/>
                <field name="lead_count"/>
                <field name="converted_count"/>
                <field name="conversion_rate" widget="progressbar"/>
            </list>
        </field>
    </record>

    <record id="jil_nurturing_campaign_form_view" model="ir.ui.view">
        <field name="name">jil.nurturing.campaign.form</field>
        <field name="model">jil.nurturing.campaign</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_enroll_leads" type="object" string="Enroll Eligible Leads"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="campaign_type"/>
                            <field name="active"/>
                            <field name="team_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="lead_count"/>
                            <field name="conversion_rate" widget="progressbar"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <group string="Targeting">
                        <field name="tag_ids" widget="many2many_tags"/>
                        <field name="min_score"/>
                        <field name="max_score"/>
                    </group>
                    <notebook>
                        <page string="Campaign Steps">
                            <field name="step_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="step_type"/>
                                    <field name="delay_days"/>
                                    <field name="email_template_id"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Enrolled Leads">
                            <field name="lead_ids" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="jil_nurturing_campaign_action" model="ir.actions.act_window">
        <field name="name">Nurturing Campaigns</field>
        <field name="res_model">jil.nurturing.campaign</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
