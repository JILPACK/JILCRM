<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="jil_email_sequence_list_view" model="ir.ui.view">
        <field name="name">jil.email.sequence.list</field>
        <field name="model">jil.email.sequence</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="model"/>
                <field name="trigger_event"/>
                <field name="template_id"/>
                <field name="delay_hours"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="jil_email_sequence_form_view" model="ir.ui.view">
        <field name="name">jil.email.sequence.form</field>
        <field name="model">jil.email.sequence</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                        <field name="model"/>
                        <field name="trigger_event"/>
                        <field name="trigger_stage_id"/>
                        <field name="min_score"/>
                        <field name="delay_hours"/>
                    </group>
                    <group string="Email Config">
                        <field name="template_id"/>
                        <field name="send_to"/>
                        <field name="custom_email"/>
                        <field name="cc_to"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="jil_email_sequence_action" model="ir.actions.act_window">
        <field name="name">Email Sequences</field>
        <field name="res_model">jil.email.sequence</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
