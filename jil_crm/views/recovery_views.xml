<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="jil_recovery_list_view" model="ir.ui.view">
        <field name="name">jil.recovery.list</field>
        <field name="model">jil.recovery</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list decoration-danger="status in ('en_attente', 'contentieux')" decoration-warning="status in ('relance_email', 'relance_telephone')" decoration-success="status == 'resolu'">
                <field name="name"/>
                <field name="client_id"/>
                <field name="invoice_number"/>
                <field name="amount" widget="monetary"/>
                <field name="status" widget="badge"/>
                <field name="contact_type" optional="hide"/>
                <field name="agreement_date" optional="hide"/>
                <field name="user_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="jil_recovery_form_view" model="ir.ui.view">
        <field name="name">jil.recovery.form</field>
        <field name="model">jil.recovery</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Recovery">
                <header>
                    <field name="status" widget="statusbar" clickable="True"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="client_id"/>
                            <field name="invoice_id"/>
                            <field name="invoice_number"/>
                            <field name="amount" widget="monetary"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="contact_type"/>
                            <field name="contact_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Follow-up">
                        <field name="email_sent"/>
                        <field name="phone_called"/>
                        <field name="agreement_date" invisible="status != 'accord'"/>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="jil_recovery_search_view" model="ir.ui.view">
        <field name="name">jil.recovery.search</field>
        <field name="model">jil.recovery</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="client_id"/>
                <field name="invoice_number"/>
                <filter name="filter_pending" string="Pending" domain="[('status', 'not in', ('resolu', 'contentieux'))]"/>
                <filter name="filter_resolved" string="Resolved" domain="[('status', '=', 'resolu')]"/>
                <filter name="filter_litigation" string="Litigation" domain="[('status', '=', 'contentieux')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_client" string="Client" context="{'group_by': 'client_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="jil_recovery_action" model="ir.actions.act_window">
        <field name="name">Recoveries</field>
        <field name="res_model">jil.recovery</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="jil_recovery_search_view"/>
    </record>
</odoo>
