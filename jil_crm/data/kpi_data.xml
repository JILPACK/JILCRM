<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="jil_kpi_monthly_revenue" model="jil.crm.kpi">
            <field name="name">Monthly Revenue Target</field>
            <field name="kpi_type">revenue</field>
            <field name="sequence">10</field>
            <field name="model_name">jil.crm.lead</field>
            <field name="measure_field">expected_revenue</field>
            <field name="aggregation">sum</field>
            <field name="target_value">500000</field>
            <field name="target_type">monthly</field>
            <field name="unit">$</field>
            <field name="domain">[('stage_id.is_won', '=', True)]</field>
        </record>

        <record id="jil_kpi_lead_conversion" model="jil.crm.kpi">
            <field name="name">Lead to Opportunity Conversion</field>
            <field name="kpi_type">conversion</field>
            <field name="sequence">20</field>
            <field name="model_name">jil.crm.lead</field>
            <field name="aggregation">ratio</field>
            <field name="target_value">30</field>
            <field name="target_type">monthly</field>
            <field name="unit">%</field>
        </record>

        <record id="jil_kpi_new_leads" model="jil.crm.kpi">
            <field name="name">New Leads (Monthly)</field>
            <field name="kpi_type">leads</field>
            <field name="sequence">30</field>
            <field name="model_name">jil.crm.lead</field>
            <field name="aggregation">count</field>
            <field name="target_value">100</field>
            <field name="target_type">monthly</field>
            <field name="unit">#</field>
            <field name="domain">[('type', '=', 'lead')]</field>
        </record>

        <record id="jil_kpi_pipeline_value" model="jil.crm.kpi">
            <field name="name">Pipeline Value</field>
            <field name="kpi_type">pipeline</field>
            <field name="sequence">40</field>
            <field name="model_name">jil.crm.lead</field>
            <field name="measure_field">expected_revenue</field>
            <field name="aggregation">sum</field>
            <field name="target_value">2000000</field>
            <field name="target_type">monthly</field>
            <field name="unit">$</field>
            <field name="domain">[('type', '=', 'opportunity'), ('stage_id.is_lost', '=', False)]</field>
        </record>

        <record id="jil_kpi_satisfaction" model="jil.crm.kpi">
            <field name="name">Customer Satisfaction</field>
            <field name="kpi_type">satisfaction</field>
            <field name="sequence">50</field>
            <field name="model_name">jil.consultation.booking</field>
            <field name="aggregation">avg</field>
            <field name="measure_field">satisfaction_score</field>
            <field name="target_value">4.0</field>
            <field name="target_type">monthly</field>
            <field name="unit">/5</field>
        </record>
    </data>
</odoo>
