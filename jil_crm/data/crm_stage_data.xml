<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="jil_crm_stage_new" model="jil.crm.stage">
            <field name="name">New</field>
            <field name="sequence">10</field>
            <field name="probability">0</field>
            <field name="is_default">True</field>
            <field name="color">0</field>
        </record>

        <record id="jil_crm_stage_qualified" model="jil.crm.stage">
            <field name="name">Qualified</field>
            <field name="sequence">20</field>
            <field name="probability">20</field>
            <field name="color">1</field>
        </record>

        <record id="jil_crm_stage_proposal" model="jil.crm.stage">
            <field name="name">Proposition</field>
            <field name="sequence">30</field>
            <field name="probability">50</field>
            <field name="color">2</field>
        </record>

        <record id="jil_crm_stage_negotiation" model="jil.crm.stage">
            <field name="name">Negotiation</field>
            <field name="sequence">40</field>
            <field name="probability">75</field>
            <field name="color">3</field>
        </record>

        <record id="jil_crm_stage_won" model="jil.crm.stage">
            <field name="name">Won</field>
            <field name="sequence">50</field>
            <field name="probability">100</field>
            <field name="is_won">True</field>
            <field name="color">10</field>
        </record>

        <record id="jil_crm_stage_lost" model="jil.crm.stage">
            <field name="name">Lost</field>
            <field name="sequence">60</field>
            <field name="probability">0</field>
            <field name="is_lost">True</field>
            <field name="color">9</field>
        </record>
    </data>
</odoo>
