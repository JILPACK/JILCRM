<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="jil_workflow_lead_assignment" model="jil.workflow.automation">
            <field name="name">Auto-Assign New Leads</field>
            <field name="sequence">10</field>
            <field name="model">jil.crm.lead</field>
            <field name="trigger_type">on_create</field>
            <field name="action_type">assign_user</field>
            <field name="active">True</field>
        </record>

        <record id="jil_workflow_follow_up" model="jil.workflow.automation">
            <field name="name">Follow-up on Stage Change</field>
            <field name="sequence">20</field>
            <field name="model">jil.crm.lead</field>
            <field name="trigger_type">stage_change</field>
            <field name="action_type">create_activity</field>
            <field name="activity_summary">Follow-up required for {name}</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
